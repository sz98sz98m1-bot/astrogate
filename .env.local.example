# مفتاح Anthropic Claude API (احصل عليه من console.anthropic.com)
# مطلوب لتفعيل توليد الأبراج اليومية/الأسبوعية بالذكاء الاصطناعي.
ANTHROPIC_API_KEY=

# سر مشترك لحماية مسار POST/GET /api/horoscope/refresh من الاستدعاء العشوائي.
# Vercel يرسله تلقائيًا كـ Authorization: Bearer عند تفعيل Vercel Cron.
CRON_SECRET=

# يُضاف تلقائيًا بواسطة Vercel عند ربط مخزن Vercel Blob بالمشروع (vercel blob create-store).
# مطلوب فقط في بيئة الإنتاج على Vercel للتخزين المؤقت الدائم؛ التطوير المحلي يستخدم نظام
# الملفات في /data تلقائيًا بدونه.
BLOB_READ_WRITE_TOKEN=

# رابط الموقع الفعلي (يُستخدم في robots.txt وsitemap.xml وعلامات Open Graph). اختياري محليًا.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
